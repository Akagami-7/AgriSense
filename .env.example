# AgriSense API Configuration
# Copy this file to .env and fill in your keys

# Google Gemini API Key (for AI Crop Disease Detection)
# Get one for free at: https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeatherMap API Key (for Real-time Weather & Risks)
# Get one for free at: https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=your_openweathermap_api_key_here
